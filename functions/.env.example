# PsyClinicAI backend secrets — copy to .env (gitignored) and fill in.
# NEVER commit real values.

# Anthropic (server-side relay so the key never reaches the browser)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Stripe
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_SOLO=price_REPLACE_ME
STRIPE_PRICE_PRACTICE=price_REPLACE_ME
STRIPE_PRICE_GROUP=price_REPLACE_ME

# Where the web app is served (CORS + checkout redirect targets)
APP_URL=https://app.psyclinicai.com
