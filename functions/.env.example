# PsyClinicAI backend secrets — copy to .env (gitignored) and fill in.
# NEVER commit real values.
#
# Loader behaviour: `functions/src/lib/env.ts` reads each variable
# lazily and *throws* when one is missing on first access, so a
# misconfigured deploy crashes on cold start instead of calling
# upstream APIs with an empty bearer token.

# LLM providers — Sprint 30 free-tier launch (PILAR 1 + PILAR 4).
#
# Provider chain order (first configured wins; empty keys skipped):
#   1. Groq (FREE, no BAA — demo / sandbox / non-PHI only)
#   2. Gemini (FREE, no BAA — secondary free fallback)
#   3. Anthropic (PAID, BAA available — turn on for PHI workloads)
#   4. Azure OpenAI (PAID, BAA standard — fallback for PHI)
#
# Bootstrap launch: only Groq + Gemini are required. Anthropic + Azure
# come online once revenue covers the Anthropic Startup tier OR a
# user pastes their BYOK Anthropic key (Settings → API keys).

# Groq free tier (https://console.groq.com) — primary for demo / sandbox.
GROQ_API_KEY=gsk_REPLACE_ME

# Gemini free tier (https://aistudio.google.com/apikey) — free fallback.
GEMINI_API_KEY=AIzaREPLACE_ME

# Anthropic — PAID, BAA-available. Empty key = skipped in the chain.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_PROXY_API_KEY=sk-ant-REPLACE_ME

# Azure OpenAI — PAID, BAA-standard. Empty triplet = skipped.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Stripe — subscription billing
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_SOLO=price_REPLACE_ME
STRIPE_PRICE_PRACTICE=price_REPLACE_ME
STRIPE_PRICE_GROUP=price_REPLACE_ME

# Daily.co — telehealth room minting (Sprint 11)
DAILY_API_KEY=REPLACE_ME

# CORS — comma-separated allow-list. Falls back to APP_URL if unset.
ALLOWED_ORIGINS=https://app.psyclinicai.com,https://staging.psyclinicai.com

# Where the web app is served (CORS fallback + checkout redirect targets)
APP_URL=https://app.psyclinicai.com
